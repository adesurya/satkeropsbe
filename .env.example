# =============================================
# APPLICATION CONFIG
# =============================================
NODE_ENV=development
PORT=5000
APP_NAME=CrimeDashboardAPI
API_VERSION=v1
APP_URL=http://localhost:5000

# =============================================
# DATABASE CONFIG (MySQL)
# =============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crime_dashboard
DB_USER=root
DB_PASS=your_strong_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# =============================================
# JWT CONFIG
# =============================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# REDIS CONFIG (Optional - for caching)
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# =============================================
# BCRYPT CONFIG
# =============================================
BCRYPT_SALT_ROUNDS=12

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# =============================================
# EXTERNAL API SOURCE CONFIG
# =============================================
SOURCE_API_BASE_URL=http://localhost:3000/api/v1
SOURCE_API_TOKEN=your_source_api_token_here
SOURCE_API_TIMEOUT=30000

# =============================================
# LOGGING CONFIG
# =============================================
LOG_LEVEL=info
LOG_DIR=logs

# =============================================
# CORS CONFIG
# =============================================
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4000

# =============================================
# OPENAI (for AI Insight)
# =============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
